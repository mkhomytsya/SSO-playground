# ─── Pocket ID ────────────────────────────────────────────────
# Public URL the browser uses to reach Pocket ID (OIDC issuer).
POCKET_ID_APP_URL=http://localhost:1411

# ─── oauth2-proxy ─────────────────────────────────────────────
# Paste these AFTER creating an OIDC client in Pocket ID's admin UI.
OAUTH2_PROXY_CLIENT_ID=<paste-client-id-here>
OAUTH2_PROXY_CLIENT_SECRET=<paste-client-secret-here>

# Cookie encryption key — generate with:
#   openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=<paste-generated-secret-here>

# Where oauth2-proxy tells Pocket ID to redirect after login.
OAUTH2_PROXY_REDIRECT_URL=https://localhost:4443/oauth2/callback
